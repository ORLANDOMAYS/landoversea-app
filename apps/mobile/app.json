{
  "expo": {
    "name": "LandOverSea",
    "slug": "landoversea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "landoversea",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e11d48"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.landoversea.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LandOverSea needs camera access for profile verification",
        "NSPhotoLibraryUsageDescription": "LandOverSea needs photo library access to upload profile photos",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:landoversea-app.vercel.app",
        "applinks:www.landoversea.net"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e11d48"
      },
      "package": "com.landoversea.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "landoversea-app.vercel.app",
              "pathPrefix": "/app"
            },
            {
              "scheme": "landoversea"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "617bda0f-5cd5-4a62-a565-4d3c2a9c3d74"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "landoversea1",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "LandOverSea needs camera access for profile verification"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "LandOverSea needs photo library access to upload profile photos"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/617bda0f-5cd5-4a62-a565-4d3c2a9c3d74"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
