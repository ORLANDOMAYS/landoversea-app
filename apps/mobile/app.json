{
  "expo": {
    "name": "LandOverSea",
    "slug": "landoversea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "landoversea",
    "splash": {
      "backgroundColor": "#e11d48"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.landoversea.app",
      "infoPlist": {
        "NSCameraUsageDescription": "LandOverSea needs camera access for profile verification"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#e11d48"
      },
      "package": "com.landoversea.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "LandOverSea needs camera access for profile verification"
        }
      ]
    ]
  }
}
